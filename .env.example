# SafeNest Environment Configuration Template
# Copy this file to .env and update with your values
# NEVER commit .env file to version control

# Database Configuration
DATABASE_URL=jdbc:mysql://hostname:3306/safenest_db
DATABASE_USER=safenest_user
DATABASE_PASSWORD=your_secure_password_here

# Server Configuration
SERVER_PORT=8080

# Frontend Configuration
FRONTEND_URL=https://your-frontend-domain.com

# Frontend API Configuration (for React app)
VITE_API_URL=http://localhost:8080

# Admin Configuration
ADMIN_PASSWORD=your_admin_password_here

# Optional: Additional Spring profiles
SPRING_PROFILES_ACTIVE=prod

# Optional: Java memory settings
JAVA_OPTS=-Xmx1024m -Xms512m
